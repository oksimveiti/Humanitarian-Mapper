# Copy this file to `.env` and set real values for production.
# Docker Compose reads `.env` automatically. Do NOT commit your real `.env`.

# Secret used to sign JWTs. MUST be at least 32 characters. Change this!
JWT_SECRET=please-change-me-to-a-long-random-secret-min-32-bytes

# Initial coordinator account, created on first startup.
ADMIN_EMAIL=admin@example.org
ADMIN_PASSWORD=change-this-admin-password
